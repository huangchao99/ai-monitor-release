; Copy your validated ZLMediaKit config.ini here and keep site-specific edits in /etc/ai-monitor/zlm/config.ini
; Required reminders:
; 1. API secret must match AI_MONITOR_ZLM_SECRET
; 2. ffmpeg path must point to /opt/ffmpeg-rk/bin/ffmpeg
; 3. http port should stay aligned with the reverse proxy design

[api]
secret=change_me

[ffmpeg]
bin=/opt/ffmpeg-rk/bin/ffmpeg
