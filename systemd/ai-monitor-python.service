[Unit]
Description=AI Monitor Python Service
After=network-online.target infer-server.service
Wants=network-online.target
Requires=infer-server.service

[Service]
Type=simple
User=root
Group=root
EnvironmentFile=/etc/ai-monitor/python.env
WorkingDirectory=/opt/ai-monitor/current/python/app
ExecStart=/bin/sh -c 'if [ -x /opt/ai-monitor/current/python/venv/bin/python ]; then exec /opt/ai-monitor/current/python/venv/bin/python /opt/ai-monitor/current/python/app/main.py; fi; exec python3 /opt/ai-monitor/current/python/app/main.py'
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
