[Unit]
Description=AI Monitor Go Backend
After=network-online.target ai-monitor-python.service zlmediakit.service
Wants=network-online.target
Requires=ai-monitor-python.service zlmediakit.service

[Service]
Type=simple
User=root
Group=root
EnvironmentFile=/etc/ai-monitor/backend.env
WorkingDirectory=/opt/ai-monitor/current
ExecStart=/opt/ai-monitor/current/bin/ai-monitor-backend
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
